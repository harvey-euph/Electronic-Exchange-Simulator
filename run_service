#!/bin/bash

PROJECT_ROOT="$(cd "$(dirname "$0")" && pwd)"
LOG_DIR="$PROJECT_ROOT/log"
SESSION="exchange"

mkdir -p "$LOG_DIR"

declare -A SERVICES=(
    ["Order Core"]="build/app/order_core"
    ["HTTP Order Accepter"]="build/app/http_accepter"
    ["Client Manager"]="build/app/client_manager"
    ["L2 Publisher"]="build/app/l2_publisher"
    ["L3 Publisher"]="build/app/l3_publisher"
)

SERVICE_NAMES=("Order Core" "HTTP Order Accepter" "Client Manager" "L2 Publisher" "L3 Publisher")

declare -A SERVICE_LOGS=(
    ["Order Core"]="order_core.log"
    ["HTTP Order Accepter"]="http_order_accepter.log"
    ["Client Manager"]="client_manager.log"
    ["L2 Publisher"]="level_2_publisher.log"
    ["L3 Publisher"]="level_3_publisher.log"
)

# Check if session already exists
if tmux has-session -t "$SESSION" 2>/dev/null; then
    echo "Re-attaching to existing session '$SESSION'..."
    echo "To stop everything, press [Ctrl+C] inside the Monitor window."
    sleep 1
    if [ -n "$TMUX" ]; then
        tmux switch-client -t "$SESSION"
    else
        tmux attach-session -t "$SESSION"
    fi
    exit 0
fi

# Start a new detached session
# Window 0 is a normal shell for terminal manipulation and monitoring
tmux new-session -d -s "$SESSION" -n "Monitor" "bash"

# Configure status bar for help
tmux set-option -t "$SESSION" status-bg black
tmux set-option -t "$SESSION" status-fg white
# tmux set-option -t "$SESSION" status-left-length 60
# tmux set-option -t "$SESSION" status-left "#[fg=cyan][Ctrl+B, Arrows: Switch] #[fg=yellow][Ctrl+B, w: List (q to exit)] "
# tmux set-option -t "$SESSION" status-right-length 40
# tmux set-option -t "$SESSION" status-right "#[fg=green][Ctrl+B, d: Detach] "

# Bind Ctrl+B + Arrows to switch windows easily
tmux bind-key -r Left select-window -t :-
tmux bind-key -r Right select-window -t :+

# Create windows for each service
for name in "${SERVICE_NAMES[@]}"; do
    log="$LOG_DIR/${SERVICE_LOGS[$name]}"
    exe="${SERVICES[$name]}"
    
    # Run the service in a loop for health check/auto-restart
    tmux new-window -t "$SESSION" -n "$name" "bash -c 'while true; do echo \"--- Starting $name ---\"; $PROJECT_ROOT/$exe 2>&1 | tee -a $log; echo \"--- $name crashed, restarting in 2s ---\"; sleep 2; done'"
done

# Select the Monitor window by default
tmux select-window -t "$SESSION":0

# Create the monitor loop and send it to Window 0
# Use tput to move cursor to home and clear lines individually for a flicker-free "top" like experience
MONITOR_CMD=$(cat <<EOF
trap "break" SIGINT SIGTERM
while true; do
    tput cup 0 0
    echo -n "================================================================================"; tput el; echo ""
    echo -n "EXCHANGE PROCESS MONITOR - [Ctrl+B, d] to Detach"; tput el; echo ""
    echo -n "================================================================================"; tput el; echo ""
    printf "%-25s %-10s %-10s %-10s %-10s" "SERVICE" "STATUS" "PID" "%CPU" "MEM(MB)"; tput el; echo ""
    echo -n "--------------------------------------------------------------------------------"; tput el; echo ""
    for name in "order_core" "http_accepter" "client_manager" "l2_publisher" "l3_publisher"; do
        # Use -n (newest) and match the end of the command line to avoid the bash wrapper
        PID=\$(pgrep -n -f "/\$name\$")
        if [ -n "\$PID" ]; then
            STATS=\$(ps -p \$PID -o pcpu,rss --no-headers 2>/dev/null)
            if [ -n "\$STATS" ]; then
                CPU=\$(echo \$STATS | awk '{print \$1}')
                RSS_KB=\$(echo \$STATS | awk '{print \$2}')
                RSS_MB=\$(echo \$RSS_KB | awk '{printf "%.1f", \$1/1024}')
                printf "%-25s %-10s %-10s %-10s %-10s" "\$name" "ALIVE" "\$PID" "\$CPU%" "\${RSS_MB}MB"
            else
                printf "%-25s %-10s %-10s %-10s %-10s" "\$name" "STARTING" "\$PID" "-" "-"
            fi
        else
            printf "%-25s %-10s %-10s %-10s %-10s" "\$name" "DEAD" "-" "-" "-"
        fi
        tput el; echo ""
    done
    echo -n "================================================================================"; tput el; echo ""
    echo ""
    echo -n "================================================================================"; tput el; echo ""
    printf "%-25s %-10s %-21s %-10s" "SHARED MEMORY" "STATUS" "" "SIZE"; tput el; echo ""
    echo -n "--------------------------------------------------------------------------------"; tput el; echo ""
    for shm in "ORDER_REQUEST" "ORDER_RESPONSE" "L2_UPDATE_RING" "L3_UPDATE_RING"; do
        if [ -e "/dev/shm/\$shm" ]; then
            SIZE=\$(du -h "/dev/shm/\$shm" | awk '{print \$1}')
            printf "%-25s %-10s %-21s %-10s" "\$shm" "EXISTS" "" "\$SIZE"
        else
            printf "%-25s %-10s %-21s %-10s" "\$shm" "MISSING" "" "-"
        fi
        tput el; echo ""
    done
    echo -n "================================================================================"; tput el; echo ""
    echo -n " Press [Ctrl+C] in THIS window to STOP ALL SERVICES."; tput el; echo ""
    echo -n " Press [Ctrl+B] then [d] to DETACH (services keep running)."; tput el; echo ""
    tput ed
    sleep 2
done
echo "Stopping all services..."
pkill -f "build/app/"
rm -f /dev/shm/*RING /dev/shm/ORDER_*
tmux kill-session -t "\$SESSION"
EOF
)

tmux send-keys -t "$SESSION":0 "$MONITOR_CMD" C-m

# Attach to the session
if [ -n "$TMUX" ]; then
    tmux switch-client -t "$SESSION"
else
    tmux attach-session -t "$SESSION"
fi
