#!/bin/bash

PROJECT_ROOT="$(cd "$(dirname "$0")" && pwd)"
EXE_PATH="$PROJECT_ROOT/build/client-agents/mm-native"

if [ ! -x "$EXE_PATH" ]; then
    echo "Error: Executable not found at $EXE_PATH"
    echo "Please compile the project first."
    exit 1
fi

echo "Starting mm-native for BTC (symbol_id=1, client_id=100)..."
nohup bash -c 'while true; do "$1" 100 1 >/dev/null 2>&1; sleep 2; done' "exchange_agent_service_mm_native_1" "$EXE_PATH" >/dev/null 2>&1 &

echo "Starting mm-native for ETH (symbol_id=2, client_id=101)..."
nohup bash -c 'while true; do "$1" 101 2 >/dev/null 2>&1; sleep 2; done' "exchange_agent_service_mm_native_2" "$EXE_PATH" >/dev/null 2>&1 &

echo "Starting mm-native for SOL (symbol_id=3, client_id=102)..."
nohup bash -c 'while true; do "$1" 102 3 >/dev/null 2>&1; sleep 2; done' "exchange_agent_service_mm_native_3" "$EXE_PATH" >/dev/null 2>&1 &

echo "mm-native processes successfully started in the background."
