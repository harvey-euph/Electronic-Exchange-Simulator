#!/bin/bash

PROJECT_ROOT="$(cd "$(dirname "$0")" && pwd)"
EXE_PATH="$PROJECT_ROOT/build/client-agents/mm-native"

if [ ! -x "$EXE_PATH" ]; then
    echo "Error: Executable not found at $EXE_PATH"
    echo "Please compile the project first."
    exit 1
fi

echo "Starting mm-native in the background..."
nohup bash -c 'while true; do "$1" "${@:2}" >/dev/null 2>&1; sleep 2; done' "exchange_agent_service_mm_native" "$EXE_PATH" "$@" >/dev/null 2>&1 &

echo "mm-native successfully started in the background."
