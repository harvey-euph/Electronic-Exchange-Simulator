#!/bin/bash

if [ "$EUID" -ne 0 ]; then
    echo "Warning: Running without sudo/root. System tuning and real-time scheduling (chrt) will be skipped." >&2
    HAS_ROOT=0
else
    HAS_ROOT=1
fi

PROJECT_ROOT="$(cd "$(dirname "$0")" && pwd)"
source "$PROJECT_ROOT/scripts/system-tuning.sh"
BUILD_SERVICE_DIR="$PROJECT_ROOT/build/services"
LOG_DIR="$PROJECT_ROOT/log"
SESSION="exchange"

mkdir -p "$LOG_DIR"

JOURNAL_DIR="$PROJECT_ROOT/log/execution-journals"
mkdir -p "$JOURNAL_DIR"
if [ "$HAS_ROOT" -eq 1 ]; then
    apply_system_tuning
fi

# Check if any service is running (processes are active)
if pgrep -f "build/services/" >/dev/null; then
    echo "One or more core services are already running. Stopping services and cleaning up shared memory..."
    if [ "$HAS_ROOT" -eq 1 ]; then
        sudo "$PROJECT_ROOT/kill-all"
    else
        "$PROJECT_ROOT/kill-all"
    fi
fi

# We don't need sudo askpass here
SUDO_CMD=""
CHRT_CMD=""
if [ "$HAS_ROOT" -eq 1 ]; then
    CHRT_CMD="chrt -f 99"
fi

# Explicitly list the services to start
SERVICES=(
    "client-manager"
    "market-data-server"
    "public-data"
)

echo "Starting $SESSION services in the background..."

# Start regular services
for name in "${SERVICES[@]}"; do
    exe="$BUILD_SERVICE_DIR/$name"
    if [ ! -x "$exe" ]; then
        echo "Error: Executable $exe not found. Please compile first."
        exit 1
    fi
    run_cmd="$CHRT_CMD $exe"
    nohup bash -c "while true; do $run_cmd >/dev/null 2>&1; sleep 2; done" "exchange_core_service_$name" >/dev/null 2>&1 &
done

# Start matching-engine separately for each core
ME_EXE="$BUILD_SERVICE_DIR/matching-engine"
if [ ! -x "$ME_EXE" ]; then
    echo "Error: Executable $ME_EXE not found. Please compile first."
    exit 1
fi

CORES=(0)
for core in "${CORES[@]}"; do
    run_cmd="$CHRT_CMD $ME_EXE $core"
    nohup bash -c "while true; do $run_cmd >/dev/null 2>&1; sleep 2; done" "exchange_core_service_matching-engine_${core}" >/dev/null 2>&1 &
done

if [ "$HAS_ROOT" -eq 1 ]; then
    $SUDO_CMD systemctl start nginx 2>/dev/null || true
fi
echo "Services successfully started in the background."
