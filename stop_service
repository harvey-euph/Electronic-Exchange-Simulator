#!/bin/bash

PROJECT_ROOT="$(cd "$(dirname "$0")" && pwd)"
PID_FILE="$PROJECT_ROOT/.run_service.pid"

echo "Stopping all Exchange Services..."

# 1. Stop the monitor if it's running
if [ -f "$PID_FILE" ]; then
    MONITOR_PID=$(cat "$PID_FILE")
    if kill -0 "$MONITOR_PID" 2>/dev/null; then
        echo "Stopping monitor process (PID: $MONITOR_PID)..."
        kill "$MONITOR_PID"
        sleep 1
    fi
    rm -f "$PID_FILE"
fi

# 2. Kill all binary processes
pkill -f "build/app/"

if [ $? -eq 0 ]; then
    echo "Successfully sent termination signal to all services."
else
    echo "No services found running or failed to stop services."
fi

# 3. Clean up shared memory
echo "Cleaning up shared memory..."
rm -f /dev/shm/L2_UPDATE_RING /dev/shm/L3_UPDATE_RING /dev/shm/ORDER_REQUEST /dev/shm/ORDER_RESPONSE

echo "Done."
