#!/bin/bash
PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
BUILD_DIR="$PROJECT_ROOT/build"

TARGETS=("$@")
if [ ${#TARGETS[@]} -eq 0 ]; then
    # No arguments provided, default to all directories in tests/
    TARGETS=("$PROJECT_ROOT"/tests/*)
fi

for d in "${TARGETS[@]}"; do
    # Resolve to absolute path to ensure matching works properly
    d="$(cd "$d" 2>/dev/null && pwd || echo "$d")"
    
    if [ -d "$d" ] && [ -f "$d/requests.csv" ]; then
        echo "Generating expected-exec.csv for $d"
        mkdir -p "$PROJECT_ROOT/log"
        pkill -f "build/services/" >/dev/null 2>&1 || true
        pkill -f "build/components/" >/dev/null 2>&1 || true
        rm -f /dev/shm/ORDER_REQUEST /dev/shm/ORDER_RESPONSE /dev/shm/MARKET_DATA_RING 2>/dev/null || true
        rm -f "$PROJECT_ROOT/log/execution-journals/"* 2>/dev/null
        
        "$BUILD_DIR/services/matching-engine" >/dev/null 2>&1 &
        ME_PID=$!
        sleep 0.5
        
        "$BUILD_DIR/components/execution-stdout" > "$d/expected-exec.csv" 2>/dev/null &
        EXEC_PID=$!

        "$BUILD_DIR/components/csv_inserter" "$d/requests.csv"
        sleep 3
        
        kill -SIGINT $ME_PID 2>/dev/null || true
        wait $ME_PID 2>/dev/null || true
        
        kill -9 $EXEC_PID 2>/dev/null || true
    else
        echo "Skipping $d: not a valid test directory or missing requests.csv"
    fi
done
