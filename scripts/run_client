#!/bin/bash

# Get the project root directory
PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

echo "Exchange Client Runner"
echo "1) L2 Market Data Client (Legacy)"
echo "2) L3 Market Data Client"
echo "3) Client Management Client (Orders & Account)"
read -p "Select client type [1-3]: " choice

case $choice in
    1)
        "$PROJECT_ROOT/build/app/cli_ws_l2" 127.0.0.1 9002 1
        ;;
    2)
        "$PROJECT_ROOT/build/app/cli_ws_l3" 127.0.0.1 9003 1
        ;;
    3)
        "$PROJECT_ROOT/build/app/cli_ws_mgmt" 127.0.0.1 9001 101
        ;;
    *)
        echo "Invalid choice."
        ;;
esac
