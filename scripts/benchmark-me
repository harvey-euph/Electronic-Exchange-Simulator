#!/bin/bash

if [ "$EUID" -ne 0 ]; then
    echo "Error: This script must be run as root/sudo." >&2
    exit 1
fi

ORDER_COUNT=${1:-10000}

PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
source "$PROJECT_ROOT/scripts/system-tuning.sh"

if pgrep -f "build/services/" >/dev/null || pgrep -f "build/client-perf/throughput-test" >/dev/null; then
    echo "Stopping existing services..."
    "$PROJECT_ROOT/kill-all"
fi

LOG_DIR="$PROJECT_ROOT/log"
mkdir -p "$LOG_DIR"
JOURNAL_DIR="$PROJECT_ROOT/log/execution-journals"
mkdir -p "$JOURNAL_DIR"
rm -f "$JOURNAL_DIR"/*
rm -f /dev/shm/ORDER_REQUEST_1 /dev/shm/ORDER_RESPONSE 2>/dev/null

apply_system_tuning

echo "Starting matching-engine..."
chrt -f 99 "$PROJECT_ROOT/build/services/matching-engine" >/dev/null 2>&1 &
ME_PID=$!

# Wait briefly to let matching-engine initialize SHM
sleep 1

echo "Running throughput-test with $ORDER_COUNT orders..."
chrt -f 99 "$PROJECT_ROOT/build/client-perf/throughput-test" "$ORDER_COUNT"

echo "Stopping matching-engine..."
kill $ME_PID
wait $ME_PID 2>/dev/null

restore_system_tuning

echo "Done."
