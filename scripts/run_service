#!/bin/bash

# Get the project root directory (one level up from this script)
PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
LOG_DIR="$PROJECT_ROOT/log"

mkdir -p "$LOG_DIR"

echo "Starting Exchange Services from $PROJECT_ROOT..."

# 1. Order Core
"$PROJECT_ROOT/build/app/ser_order_core" > "$LOG_DIR/order_core.log" 2>&1 &
echo "[1/5] Started Order Core (PID: $!)"

sleep 1

# 2. HTTP Order Accepter
"$PROJECT_ROOT/build/app/ser_http_accepter" > "$LOG_DIR/http_order_accepter.log" 2>&1 &
echo "[2/5] Started HTTP Order Accepter (PID: $!)"

# 3. Client Manager
"$PROJECT_ROOT/build/app/ser_client_manager" > "$LOG_DIR/client_manager.log" 2>&1 &
echo "[3/5] Started Client Manager (PID: $!)"

# 4. L2 Publisher
"$PROJECT_ROOT/build/app/ser_l2_publisher" > "$LOG_DIR/level_2_publisher.log" 2>&1 &
echo "[4/5] Started L2 Publisher (PID: $!)"

# 5. L3 Publisher
"$PROJECT_ROOT/build/app/ser_l3_publisher" > "$LOG_DIR/level_3_publisher.log" 2>&1 &
echo "[5/5] Started L3 Publisher (PID: $!)"

echo "------------------------------------------------"
echo "All services are running in the background."
echo "Logs are available in $LOG_DIR/"
echo "To stop all services, run: ./scripts/stop_service"
