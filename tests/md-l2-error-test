#!/bin/bash

# Ensure we are in the project root
PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$PROJECT_ROOT"

# 1. Clean previous logs and SHM files
echo "Cleaning up old state..."
rm -rf log/* /dev/shm/ORDER_REQUEST /dev/shm/ORDER_RESPONSE
mkdir -p log/execution-journals

# 2. Start Matching Engine
echo "Starting matching-engine..."
./build/services/matching-engine > /dev/null 2>&1 &
ME_PID=$!

# 3. Start Market Data Server
echo "Starting market-data-server..."
./build/services/market-data-server > /dev/null 2>&1 &
MD_PID=$!

# 4. Start Client Manager
echo "Starting client-manager..."
./build/services/client-manager > /dev/null 2>&1 &
CM_PID=$!
sleep 1

# 5. Run CSVSender with the specific case
echo "Sending orders..."
./build/client-examples/CSVSender data/error_case.csv > /dev/null 2>&1
echo "CSVSender finished."

# 6. Stop services
echo "Stopping services..."
kill $CM_PID $MD_PID $ME_PID 2>/dev/null
wait $CM_PID $MD_PID $ME_PID 2>/dev/null

# Check if there were any FATAL errors in md.log
if grep -q "FATAL" log/services.log; then
    echo -e "\n[RESULT] ERROR: Found FATAL in market-data-server logs!"
    grep "FATAL" log/services.log
else
    echo -e "\n[RESULT] SUCCESS: No FATAL errors found in market-data-server logs!"
fi

echo "Done."
